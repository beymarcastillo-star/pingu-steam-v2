# --- WHATSAPP ---
ADMIN_NUMBER=59175801614

# --- SERVIDOR ---
PORT=3000
TZ=America/La_Paz

# --- SEGURIDAD (Panel Admin) ---
PANEL_PASSWORD=admin123
